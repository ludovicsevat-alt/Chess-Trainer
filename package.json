{
  "name": "chess-trainer-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "npm run dev",
    "clean": "rd /s /q dist && echo Dossier dist supprimé",
    "zip": "powershell Compress-Archive -Path . -DestinationPath ../chess-trainer-v2_backup_$(Get-Date -f yyyy-MM-dd_HH-mm).zip",
    "checkpoint": "git add . && git commit -m \"Checkpoint auto\" && git push",
    "reset": "git fetch origin main && git reset --hard origin/main && git clean -fd",
    "forcepush": "git add . && git commit -m \"Force push\" && git push -f origin main",
    "update-readme": "git add README.md && git commit -m \"Mise à jour du README\" && git push"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "framer-motion": "^12.23.24",
    "react": "^19.1.1",
    "react-chessboard": "^5.6.2",
    "react-dom": "^19.1.1",
    "stockfish": "^17.1.0",
    "stockfish.wasm": "^0.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.7"
  }
}
